# ── Tiresias Configuration ────────────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# Zero YAML required for basic setup — env vars only.

# ── License ───────────────────────────────────────────────────────────────────
# JWT license token issued by Saluca. Required — container refuses to start without it.
TIRESIAS_LICENSE_TOKEN=

# Optional: override default renewal endpoint
TIRESIAS_RENEWAL_URL=https://license.saluca.com/v1/renew

# Optional: route renewal through your on-prem relay proxy
TIRESIAS_RELAY_URL=

# Optional: HTTPS proxy for phone-home renewal requests (e.g. corporate environments)
HTTPS_PROXY=

# ── Ports (override defaults) ─────────────────────────────────────────────────
PROXY_PORT=8080
DASHBOARD_PORT=3000
RELAY_PORT=8090

# ── AI Provider Keys ──────────────────────────────────────────────────────────
# At least one provider key required for the proxy to forward requests.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ── Storage ───────────────────────────────────────────────────────────────────
# SQLite (default, zero config):
DATABASE_URL=sqlite:////app/data/tiresias.db

# Postgres (recommended for production):
# DATABASE_URL=postgresql://user:password@host:5432/tiresias

# ── Encryption ────────────────────────────────────────────────────────────────
# 32-byte hex key for encrypting stored prompt/response data at rest.
# Generate: python3 -c "import secrets; print(secrets.token_hex(32))"
ENCRYPTION_KEY=

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=info
